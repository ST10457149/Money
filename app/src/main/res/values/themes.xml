<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MoneyGoat" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryDark">@color/primary_green_dark</item>
        <item name="colorAccent">@color/accent_gold</item>
        <item name="android:windowBackground">@color/background_cream</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/black</item>
        <item name="android:editTextColor">@color/black</item>
        <item name="materialButtonStyle">@style/Widget.MoneyGoat.Button</item>
    </style>

    <style name="Widget.MoneyGoat.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary_green_light</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>