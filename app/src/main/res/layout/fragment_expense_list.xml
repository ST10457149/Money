<?xml version="1.0" encoding="utf-8"?>
<!--
    Screen displaying a filterable history of all expenses.
    Includes date pickers for range selection and a RecyclerView for the list.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_cream">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Expense History"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="12dp"/>

    <!-- Summary Section -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        android:layout_marginBottom="12dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">
            <TextView
                android:id="@+id/tvListSummary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total for period: R 0.00"
                android:textStyle="bold"
                android:textColor="@color/black"/>
            <TextView
                android:id="@+id/tvListCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 items"
                android:textColor="@color/black"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Search Bar -->
    <EditText
        android:id="@+id/etSearchExpense"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Search expenses..."
        android:textColor="@color/black"
        android:textColorHint="@color/black"
        android:drawableStart="@android:drawable/ic_menu_search"
        android:padding="10dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="8dp"/>

    <!-- Filter Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- Start Date Selector -->
        <Button
            android:id="@+id/btnFilterStart"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:textSize="11sp"
            android:backgroundTint="@color/button_light"
            android:textColor="@color/black"
            android:layout_marginEnd="4dp"/>

        <!-- End Date Selector -->
        <Button
            android:id="@+id/btnFilterEnd"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:textSize="11sp"
            android:backgroundTint="@color/button_light"
            android:textColor="@color/black"
            android:layout_marginEnd="4dp"/>

        <!-- Apply Filter Button -->
        <Button
            android:id="@+id/btnApplyFilter"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="Filter"
            android:textSize="12sp"
            android:backgroundTint="@color/primary_green"
            android:textColor="@color/black"/>

    </LinearLayout>

    <!-- Empty State Placeholder -->
    <TextView
        android:id="@+id/tvEmptyList"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No expenses found for this period."
        android:textAlignment="center"
        android:textColor="@color/black"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- Main Expense List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExpenses"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <!-- Export Button -->
    <Button
        android:id="@+id/btnExportCsv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Export to CSV"
        android:backgroundTint="@color/accent_gold"
        android:textColor="@color/black"
        android:layout_marginTop="8dp"/>
</LinearLayout>
