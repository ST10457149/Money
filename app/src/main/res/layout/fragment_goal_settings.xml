<?xml version="1.0" encoding="utf-8"?>
<!--
    Screen for setting monthly financial targets.
    Allows users to define a minimum savings goal and a maximum spending limit
    using SeekBars for quick selection and EditTexts for precise input.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@color/background_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Budget Goals"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_marginBottom="4dp"/>

        <!-- Display for current target month -->
        <TextView
            android:id="@+id/tvGoalMonth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Minimum Goal Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Minimum Monthly Goal"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvMinValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 0"
                    android:textSize="12sp"
                    android:textColor="@color/black"/>

                <SeekBar
                    android:id="@+id/seekBarMin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="50000"
                    android:progressTint="@color/primary_green"
                    android:thumbTint="@color/primary_green"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etMinGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter minimum (R)"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edit_text_bg"
                    android:padding="12dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:layout_marginBottom="20dp"/>

                <!-- Maximum Goal Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maximum Monthly Goal"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvMaxValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R 0"
                    android:textSize="12sp"
                    android:textColor="@color/black"/>

                <SeekBar
                    android:id="@+id/seekBarMax"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="100000"
                    android:progressTint="@color/accent_gold"
                    android:thumbTint="@color/accent_gold"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etMaxGoal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter maximum (R)"
                    android:inputType="numberDecimal"
                    android:background="@drawable/edit_text_bg"
                    android:padding="12dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/black"
                    android:layout_marginBottom="12dp"/>

                <!-- Suggestion Section -->
                <LinearLayout
                    android:id="@+id/layoutSuggestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="8dp"
                    android:background="@drawable/insight_bg"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp"
                    android:visibility="gone">
                    <TextView
                        android:id="@+id/tvSuggestion"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Based on your history, we suggest: R0"
                        android:textSize="12sp"
                        android:textColor="@color/primary_green"/>
                    <Button
                        android:id="@+id/btnApplySuggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Use"
                        android:textSize="10sp"
                        style="?android:attr/borderlessButtonStyle"
                        android:textColor="@color/primary_green"/>
                </LinearLayout>

                <!-- Save Button -->
                <Button
                    android:id="@+id/btnSaveGoal"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Save Goals"
                    android:textSize="16sp"
                    android:backgroundTint="@color/primary_green"
                    android:textColor="@color/black"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
