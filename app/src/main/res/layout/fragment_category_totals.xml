<?xml version="1.0" encoding="utf-8"?>
<!--
    Screen showing spending breakdown by category.
    Displays categorical totals and a grand total for a selected date range.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Title and Export -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category Totals"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnExportPdf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PDF"
                android:textColor="@color/black"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>

            <Button
                android:id="@+id/btnExportCsv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CSV"
                android:textColor="@color/black"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- Filter Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp">

        <Spinner
            android:id="@+id/spinnerAccountFilter"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- Start Date Filter -->
            <Button
                android:id="@+id/btnCatFilterStart"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:textSize="11sp"
                android:backgroundTint="@color/button_light"
                android:textColor="@color/black"
                android:layout_marginEnd="4dp"/>

            <!-- End Date Filter -->
            <Button
                android:id="@+id/btnCatFilterEnd"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:textSize="11sp"
                android:backgroundTint="@color/button_light"
                android:textColor="@color/black"
                android:layout_marginEnd="4dp"/>

            <!-- Apply Button -->
            <Button
                android:id="@+id/btnCatApplyFilter"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Filter"
                android:textSize="12sp"
                android:backgroundTint="@color/primary_green"
                android:textColor="@color/black"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Overall Sum for the period -->
    <TextView
        android:id="@+id/tvGrandTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total: R 0.00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:paddingTop="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"/>

    <TextView
        android:id="@+id/tvMinMaxDisplay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Min: R 0.00 | Max: R 0.00"
        android:textSize="14sp"
        android:textColor="@color/black"
        android:paddingBottom="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginBottom="8dp"/>

    <!-- Charts for Visual Analytics -->
    <com.github.mikephil.charting.charts.PieChart
        android:id="@+id/pieChart"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginBottom="8dp"/>

    <com.github.mikephil.charting.charts.BarChart
        android:id="@+id/barChart"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Spending Trend"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="8dp"/>

    <com.github.mikephil.charting.charts.LineChart
        android:id="@+id/lineChart"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvTrendInsights"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Analyze your trends above!"
        android:textStyle="italic"
        android:textColor="@color/black"
        android:padding="8dp"
        android:background="@drawable/insight_bg"
        android:layout_marginBottom="16dp"/>

    <!-- Empty State Text -->
    <TextView
        android:id="@+id/tvEmptyCat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No data for this period."
        android:textAlignment="center"
        android:textColor="@color/black"
        android:padding="32dp"
        android:visibility="gone"/>

    <!-- List of Category Totals -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCategoryTotals"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"/>
    </LinearLayout>
</ScrollView>
