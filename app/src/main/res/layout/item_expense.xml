<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for a single expense item in a list (RecyclerView).
    Displays description, date, time, an optional camera icon if a photo exists, and the amount.
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Expense Description -->
            <TextView
                android:id="@+id/tvExpenseDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <!-- Date of Expense -->
            <TextView
                android:id="@+id/tvExpenseDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <!-- Category Name -->
            <TextView
                android:id="@+id/tvExpenseCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="italic"
                android:textColor="@color/black"/>

            <!-- Time range of Expense -->
            <TextView
                android:id="@+id/tvExpenseTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/black"/>

        </LinearLayout>

        <!-- Indicator showing if a receipt photo is attached -->
        <ImageView
            android:id="@+id/ivHasPhoto"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_camera"
            android:contentDescription="Has photo"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <!-- Monetary value of the expense -->
        <TextView
            android:id="@+id/tvExpenseAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
